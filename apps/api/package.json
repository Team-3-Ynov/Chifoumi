  },
  "dependencies": {
    "@chifoumi/db": "workspace:*",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.0",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/throttler": "6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "0.41.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dotenv": "^17.2.3",
    "nestjs-pino": "4.2.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "^8.16.3",
