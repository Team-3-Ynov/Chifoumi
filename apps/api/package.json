    "@types/jest": "29.5.14",
    "@types/node": "^24.12.4",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "^8.15.5",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
    "prisma": "^7.8.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "tsx": "^4.22.2",
    "typescript": "~5.7.3"
  }
