{
  "name": "@chifoumi/user-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @chifoumi/leagues build && pnpm --filter @chifoumi/db build && pnpm --filter @chifoumi/proto build",
    "pretypecheck": "pnpm --filter @chifoumi/leagues build && pnpm --filter @chifoumi/db typecheck && pnpm --filter @chifoumi/proto build",
    "pretest": "pnpm --filter @chifoumi/leagues build && pnpm --filter @chifoumi/proto build",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "prebuild": "pnpm --filter @chifoumi/proto build",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@chifoumi/db": "workspace:*",
    "@chifoumi/leagues": "workspace:*",
    "@chifoumi/proto": "workspace:*",
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/microservices": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.2.3",
    "nestjs-pino": "4.2.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "@nestjs/testing": "11.1.21",
    "@types/jest": "29.5.14",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.15.5",
    "jest": "29.7.0",
    "prisma": "^7.8.0",
    "ts-jest": "29.2.5",
    "tsx": "^4.22.2",
    "typescript": "~5.7.3"
  }
}
