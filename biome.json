{
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "extends": ["./packages/biome/shared-preset.json"],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/coverage",
      "!!**/.pnpm-store",
      "!!**/.worktrees",
      "!!pnpm-lock.yaml"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
